    if (init_mask & uiTableFlags_Reorderable)
        column->DisplayOrder = (uiTableColumnIdx)table->Columns.index_from_ptr(column);
    if (init_mask & uiTableFlags_Hideable)
        column->IsUserEnabled = column->IsUserEnabledNextFrame = (flags & uiTableColumnFlags_DefaultHide) ? 0 : 1;
    if (init_mask & uiTableFlags_Sortable) {

