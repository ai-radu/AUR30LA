static int TableFixDisplayOrderComparer(const void* lhs, const void* rhs)
{
    const uiTable* table = ((const uiTableFixDisplayOrderColumnData*)lhs)->Table;
    const uiTableColumnIdx lhs_idx = ((const uiTableFixDisplayOrderColumnData*)lhs)->Idx;
    const uiTableColumnIdx rhs_idx = ((const uiTableFixDisplayOrderColumnData*)rhs)->Idx;
    const int order_delta = (table->Columns[lhs_idx].DisplayOrder - table->Columns[rhs_idx].DisplayOrder);
    return (order_delta > 0) ? +1 : (order_delta < 0) ? -1 : (lhs_idx > rhs_idx) ? +1 : -1;
}


void UI::TableFixDisplayOrder(uiTable* table)
{
    uiContext& g = *GImGui;
    g.TempBuffer.reserve((int)(sizeof(uiTableFixDisplayOrderColumnData) * table->ColumnsCount));
    uiTableFixDisplayOrderColumnData* fdo_columns = (uiTableFixDisplayOrderColumnData*)(void*)g.TempBuffer.Data;
    for (int n = 0; n < table->ColumnsCount; n++)
    {
        fdo_columns[n].Idx = (uiTableColumnIdx)n;
        fdo_columns[n].Table = table;
    }
    ImQsort(fdo_columns, (size_t)table->ColumnsCount, sizeof(uiTableFixDisplayOrderColumnData), TableFixDisplayOrderComparer);
    for (int n = 0; n < table->ColumnsCount; n++)
        table->Columns[fdo_columns[n].Idx].DisplayOrder = (uiTableColumnIdx)n;
}

