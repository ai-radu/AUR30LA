    float len = length(a);
    if (len <= 0.0f) return {};
    return a / len;
}

inline float dot(const vec3& a, const vec3& b) {return a.x * b.x + a.y * b.y + a.z * b.z;}

inline float angle(const vec3& a, const vec3& b) {
    float d = dot(normalize(a), normalize(b));
    d = fmaxf(-1.0f, fminf(1.0f, d));
    return acosf(d);
}

inline vec3 cross(const vec3& a, const vec3& b) {
    return {
        a.y * b.z - a.z * b.y,
        a.z * b.x - a.x * b.z,
        a.x * b.y - a.y * b.x
    };
}

inline vec3 rotate(const vec3& a, float angle, const vec3& axis) {
    vec3 n = normalize(axis);
    float c = cosf(angle);
    float s = sinf(angle);
    return a * c + cross(n, a) * s + n * dot(n, a) * (1.0f - c);
}

inline m4 lookAt(const vec3& eye, const vec3& center, const vec3& up) {
    vec3 f = normalize(center - eye);
    vec3 r = normalize(cross(f, up));
    vec3 u = cross(r, f);
    m4 result = m4::identity();
    result[0][0] = r.x;
    result[1][0] = r.y;
    result[2][0] = r.z;
    result[0][1] = u.x;
    result[1][1] = u.y;
    result[2][1] = u.z;
    result[0][2] = -f.x;
    result[1][2] = -f.y;
    result[2][2] = -f.z;
    result[3][0] = -dot(r, eye);
    result[3][1] = -dot(u, eye);
    result[3][2] = dot(f, eye);
    return result;
}

inline m4 perspective(float fovy, float aspect, float zNear, float zFar) {
    float tanHalfFovy = tanf(fovy / 2.0f);
    m4 result = {};
    result[0][0] = 1.0f / (aspect * tanHalfFovy);
    result[1][1] = 1.0f / tanHalfFovy;
    result[2][2] = -(zFar + zNear) / (zFar - zNear);
    result[2][3] = -1.0f;
    result[3][2] = -(2.0f * zFar * zNear) / (zFar - zNear);
    return result;
}
